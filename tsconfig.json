{
  "compilerOptions": {
    "declaration": true,
    "declarationMap": true,
    "emitDeclarationOnly": false,
    "allowJs": true,
    "jsx": "react-jsx",
    "lib": ["DOM", "ES2020"],
    "module": "ES2020",
    "moduleResolution": "Bundler",
    "outDir": "dist",
    "rootDir": "src",
    "skipLibCheck": true,
    "strict": true,
    "target": "ES2020"
  },
  "include": [
    "src/assets.d.ts",
    "src/index.ts",
    "src/components/Button.tsx",
    "src/components/Input.tsx",
    "src/components/BetAmountInput.tsx",
    "src/components/BettingPanel.tsx",
    "src/components/GameHeaderRail.tsx",
    "src/components/GameShell.tsx",
    "src/components/Select.tsx",
    "src/components/MultiplierInput.tsx",
    "src/components/OtpInput.tsx",
    "src/components/Navigation.tsx",
    "src/data/navigationData.js",
    "src/data/navigationSvgIcons.js"
  ]
}
